rules_version = '2';

// =============================================================
//  REGLAS DE SEGURIDAD DE FIRESTORE  (versión simple)
// -------------------------------------------------------------
//  El Periquete es una app PRIVADA: para entrar hay que iniciar
//  sesión con usuario y contraseña (Firebase Authentication), y
//  las cuentas las crea solo el dueño.
//
//  Por eso la regla es simple y robusta: cualquier persona que
//  haya iniciado sesión puede leer y escribir los datos de la
//  app; quien NO inició sesión, no puede tocar nada.
//
//  Ventaja: cuando agregamos un módulo nuevo (cuentas, ventas,
//  etc.) NO hay que volver a tocar estas reglas: ya funciona.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios autenticados (logueados) pueden leer/escribir.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
